{
	"name": "baked-orm",
	"version": "0.1.0",
	"description": "Convention-over-configuration database migration tool for Bun. PostgreSQL-native with auto-generated typed schemas.",
	"license": "MIT",
	"keywords": [
		"bun",
		"postgresql",
		"migrations",
		"database",
		"schema",
		"orm",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/kklimuk/baked-orm.git"
	},
	"module": "src/index.ts",
	"type": "module",
	"bin": {
		"bake": "./src/cli.ts"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"src/",
		"LICENSE"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"knip": "^6.0.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"check": "biome check . && knip-bun && tsc --noEmit",
		"db": "bun run ./src/cli.ts",
		"test": "bun test",
		"format": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@js-temporal/polyfill": "^0.5.1"
	}
}
