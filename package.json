{
	"name": "baked-orm",
	"version": "0.14.2",
	"description": "ActiveRecord-inspired ORM and migration tool for Bun. PostgreSQL-native with auto-generated typed schemas.",
	"license": "MIT",
	"keywords": [
		"bun",
		"postgresql",
		"migrations",
		"database",
		"schema",
		"orm",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/kklimuk/baked-orm.git"
	},
	"type": "module",
	"module": "./src/index.ts",
	"types": "./dist/index.d.ts",
	"bin": {
		"bake": "./src/cli.ts"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./frontend": {
			"types": "./dist/frontend/index.d.ts",
			"default": "./src/frontend/index.ts"
		}
	},
	"files": [
		"src/",
		"dist/",
		"LICENSE"
	],
	"sideEffects": [
		"./src/index.ts",
		"./src/plugins/*.ts"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"knip": "^6.0.4",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"prepublishOnly": "bun run build",
		"check": "biome check . && knip-bun && tsc --noEmit",
		"bake": "bun run ./src/cli.ts",
		"test": "bun test",
		"format": "biome check --write .",
		"prepare": "husky",
		"publish:npm": "npm publish --access public"
	},
	"dependencies": {
		"@js-temporal/polyfill": "^0.5.1"
	}
}
